# Production backend configuration

# Required
ADMIN_TOKEN=change-this-admin-token

# Frontend domain(s) allowed to call this API
# Comma-separated if you use multiple domains
CORS_ORIGINS=https://your-frontend-domain.com

# Optional: use MongoDB in production
# If unset, backend falls back to local SQLite at LOCAL_DB_PATH
MONGO_URL=
DB_NAME=

# Preferred for Supabase Postgres
# Example:
# SUPABASE_DB_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=

# Optional: persistent local SQLite path
LOCAL_DB_PATH=/absolute/path/to/local_data.sqlite3

# Optional: external AI integration
EMERGENT_LLM_KEY=
